# =========================
# 基础模型与鉴权（至少配置一个可用的 Key）
# =========================
# Moonshot / Kimi（二选一或同时配置）
MOONSHOT_API_KEY=
KIMI_API_KEY=
# 可选：Moonshot 兼容接口地址（默认已内置）
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 可选：OpenAI 兼容 Key（若你的 LLM/Embedding 路径依赖）
OPENAI_API_KEY=


# =========================
# Neo4j 图数据库
# =========================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please_change_me
NEO4J_DATABASE=neo4j


# =========================
# Milvus 向量数据库
# 推荐优先使用 MILVUS_URI；HOST/PORT 作为兼容配置
# =========================
MILVUS_URI=http://localhost:19530
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=tcm_knowledge


# =========================
# 检索与重排
# =========================
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
BM25_TOP_K=10
TOP_K=3


# =========================
# LLM 生成参数
# =========================
LLM_MODEL=kimi-k2-0711-preview
TEMPERATURE=0.1
MAX_TOKENS=2048


# =========================
# 文本切块与图检索参数
# =========================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_GRAPH_DEPTH=2


# =========================
# 会话与持久化
# =========================
# 在线 CLI 默认会话（可留空）
SESSION_ID=123456
# SQLite checkpointer 路径（在线问答 & MCP 共用）
CHECKPOINTER_PATH=.checkpoints/tcm.db


# =========================
# LangSmith / LangChain 追踪（可选）
# =========================
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=
LANGCHAIN_PROJECT=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=
LANGSMITH_PROJECT=
